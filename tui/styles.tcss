/* TARKA — TUI Styles
   Dark glassmorphism theme with neon accent colors per entity type. */

Screen {
    background: #0a0e1a;
    layout: vertical;
}

#main-container {
    layout: horizontal;
    height: 1fr;
}

/* ── Processing Mode Pulse ──────────────────────────── */

.processing-mode {
    border: double #00d4ff;
}

.processing-mode #header-bar {
    background: #00d4ff;
    color: #0a0e1a;
}

/* ── Metrics Row ────────────────────────────────────── */

#metrics-row {
    height: 3;
    layout: horizontal;
    background: #0d1225;
    border-bottom: tall #1a2744;
    padding: 0;
}

.metric-cell {
    width: 1fr;
    text-align: center;
    color: #c0c8d8;
    padding: 1 1;
    border-right: tall #1a2744;
}

#metric-tps {
    background: #0a1f1a;
}

#metric-load {
    background: #0a1a25;
}

.metric-cell:last-child {
    border-right: none;
}

/* ── Left Panel: OSINT Feed ──────────────────────────── */

#feed-panel {
    width: 30%;
    min-width: 30;
    border: tall $accent;
    background: #0d1225;
    padding: 1;
}

#feed-title {
    dock: top;
    text-style: bold;
    color: #00d4ff;
    text-align: center;
    padding: 0 1;
    background: #111a33;
}

#feed-input {
    height: 1fr;
    border: round #1a2744;
    background: #0a0f1e;
    color: #e0e6f0;
    padding: 1;
}

#feed-buttons {
    dock: bottom;
    layout: horizontal;
    height: 3;
    align: center middle;
}

.feed-btn {
    margin: 0 1;
    min-width: 14;
    background: #152040;
    color: #00d4ff;
    border: tall #1a3060;
}

.feed-btn:hover {
    background: #1a3060;
    color: #00ffaa;
}

/* ── Center Panel: Graph Viewer ──────────────────────── */

#graph-panel {
    width: 40%;
    min-width: 40;
    border: tall $accent;
    background: #0d1225;
    padding: 1;
}

#graph-title {
    dock: top;
    text-style: bold;
    color: #ff6b6b;
    text-align: center;
    padding: 0 1;
    background: #111a33;
}

#graph-scroll {
    height: 1fr;
    background: #080c18;
    color: #c0c8d8;
    padding: 1;
    border: round #1a2744;
    overflow-y: auto;
}

#graph-view {
    width: 100%;
    color: #c0c8d8;
}

/* ── Right Panel: Intelligence Reports ───────────────── */

#report-panel {
    width: 30%;
    min-width: 30;
    border: tall $accent;
    background: #0d1225;
    padding: 1;
}

#report-title {
    dock: top;
    text-style: bold;
    color: #ffd93d;
    text-align: center;
    padding: 0 1;
    background: #111a33;
}

#report-scroll {
    height: 1fr;
    background: #080c18;
    color: #c0c8d8;
    padding: 1;
    border: round #1a2744;
    overflow-y: auto;
}

#report-view {
    width: 100%;
    color: #c0c8d8;
}

/* ── Header / Logo ───────────────────────────────────── */

#header-bar {
    height: 3;
    background: #0a0e1a;
    color: #00d4ff;
    text-align: center;
    padding: 0;
}

#logo-text {
    text-align: center;
    color: #00d4ff;
    text-style: bold;
}

/* ── Pipeline Indicator ──────────────────────────────── */

#pipeline-indicator {
    dock: bottom;
    height: 3;
    background: #0d1225;
    border-top: tall #1a2744;
    border-bottom: tall #1a2744;
    padding: 1 2;
    text-align: center;
    color: #c0c8d8;
}

/* ── Footer / Status Bar ─────────────────────────────── */

#status-bar {
    dock: bottom;
    height: 3;
    background: #111a33;
    color: #6680aa;
    padding: 0 2;
    layout: horizontal;
}

#status-left {
    width: 1fr;
    color: #6680aa;
    padding: 1 1;
}

#status-right {
    width: 1fr;
    text-align: right;
    color: #00d4ff;
    padding: 1 1;
}

/* ── Log Panel (always visible) ──────────────────────── */
/* ── Activity Container ──────────────────────────────── */

#activity-container {
    dock: bottom;
    height: 12;
    layout: horizontal;
    border-top: tall #1a2744;
    background: #080c14;
}

#log-panel {
    width: 50%;
    height: 1fr;
    padding: 0 1;
    color: #4a6080;
    overflow-y: auto;
}

/* ── Ollama Activity Widget ───────────────────────────── */

#ollama-activity {
    width: 50%;
    height: 1fr;
    background: #0d1225;
    color: #c0c8d8;
    border-left: tall #1a3060;
    padding: 0 1;
    overflow-y: auto;
}

#ollama-header {
    dock: top;
    height: 2;
    padding: 0;
    color: #00d4ff;
    text-style: bold;
}

#ollama-stream {
    height: 1fr;
    color: #c0c8d8;
    overflow-y: auto;
}

/* ── Provider Mode Themes ────────────────────────────── */

.gemini-mode #header-bar {
    background: #0a1025;
}

.gemini-mode #status-bar {
    border-top: tall #1a44aa;
}

.ollama-mode #status-bar {
    border-top: tall #1a4430;
}
